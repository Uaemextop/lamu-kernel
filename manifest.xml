<?xml version="1.0" encoding="UTF-8"?>
<!--
  Repo manifest for Moto G05 (lamu) kernel source tree.

  Replaces the manual git clone + symlink steps in the CI workflow.
  All paths are relative to the repo root (kernel_platform/).

  Usage:
    mkdir kernel_platform
    cd kernel_platform
    repo init -u URL_OF_THIS_REPO -m manifest.xml
    repo sync -c

  After sync the Bazel workspace lives under kernel/ with symlinks
  pointing to top-level external/, prebuilts/, system/, and vendor/.
-->
<manifest>

  <!-- ============================================================ -->
  <!-- Remotes                                                       -->
  <!-- ============================================================ -->
  <remote name="aosp"
          fetch="https://android.googlesource.com" />

  <remote name="moto"
          fetch="https://github.com/MotorolaMobilityLLC" />

  <default remote="aosp"
           revision="android15-release"
           sync-j="4"
           clone-depth="1" />

  <!-- ============================================================ -->
  <!-- AOSP external dependencies                                    -->
  <!-- ============================================================ -->
  <!--
    First external project carries the linkfile that creates the
    workspace symlink: kernel/external -> ../external
  -->
  <project path="external/libcap"
           name="platform/external/libcap">
    <linkfile src=".." dest="kernel/external" />
  </project>

  <project path="external/libcap-ng"
           name="platform/external/libcap-ng" />

  <project path="external/bazel-skylib"
           name="platform/external/bazel-skylib" />

  <project path="external/bazelbuild-rules_cc"
           name="platform/external/bazelbuild-rules_cc" />

  <project path="external/bazelbuild-rules_license"
           name="platform/external/bazelbuild-rules_license" />

  <project path="external/bazelbuild-rules_pkg"
           name="platform/external/bazelbuild-rules_pkg"
           revision="main-kernel" />

  <project path="external/bazelbuild-rules_python"
           name="platform/external/bazelbuild-rules_python" />

  <project path="external/bazelbuild-rules_rust"
           name="platform/external/bazelbuild-rules_rust" />

  <project path="external/stardoc"
           name="platform/external/stardoc" />

  <project path="external/zopfli"
           name="platform/external/zopfli" />

  <project path="external/pigz"
           name="platform/external/pigz"
           revision="main-kernel" />

  <project path="external/python/absl-py"
           name="platform/external/python/absl-py" />

  <!-- ============================================================ -->
  <!-- AOSP prebuilts                                                -->
  <!-- ============================================================ -->
  <project path="prebuilts/bazel/linux-x86_64"
           name="platform/prebuilts/bazel/linux-x86_64" />

  <project path="prebuilts/clang/host/linux-x86"
           name="platform/prebuilts/clang/host/linux-x86" />

  <project path="prebuilts/gcc/linux-x86/host/x86_64-linux-glibc2.17-4.8"
           name="platform/prebuilts/gcc/linux-x86/host/x86_64-linux-glibc2.17-4.8" />

  <!--
    prebuilts/build-tools carries the linkfile that creates the
    workspace symlink: kernel/prebuilts -> ../prebuilts
  -->
  <project path="prebuilts/build-tools"
           name="platform/prebuilts/build-tools">
    <linkfile src=".." dest="kernel/prebuilts" />
  </project>

  <project path="prebuilts/jdk/jdk11"
           name="platform/prebuilts/jdk/jdk11"
           revision="build-tools-release" />

  <project path="prebuilts/rust"
           name="platform/prebuilts/rust" />

  <project path="prebuilts/clang-tools"
           name="platform/prebuilts/clang-tools" />

  <!-- NDK prebuilts (toolchain server, non-default branches) -->
  <project path="prebuilts/ndk-r26"
           name="toolchain/prebuilts/ndk/r26"
           revision="main-kernel-2025" />

  <project path="prebuilts/ndk-r23"
           name="toolchain/prebuilts/ndk/r23"
           revision="main-kernel-build-2023" />

  <!-- ============================================================ -->
  <!-- AOSP build rules & system tools                               -->
  <!-- ============================================================ -->
  <!--
    build/bazel_common_rules carries the linkfile that creates the
    workspace symlink: kernel/build/bazel_common_rules -> ../../build/bazel_common_rules
  -->
  <project path="build/bazel_common_rules"
           name="platform/build/bazel_common_rules">
    <linkfile src="." dest="kernel/build/bazel_common_rules" />
  </project>

  <!--
    system/tools/mkbootimg carries two linkfiles:
      kernel/system          -> ../system
      kernel/tools/mkbootimg -> ../../system/tools/mkbootimg
  -->
  <project path="system/tools/mkbootimg"
           name="platform/system/tools/mkbootimg">
    <linkfile src="../.." dest="kernel/system" />
    <linkfile src="." dest="kernel/tools/mkbootimg" />
  </project>

  <!-- ============================================================ -->
  <!-- Motorola kernel source (GKI + build system + device modules)  -->
  <!-- ============================================================ -->
  <!-- GKI kernel source (Linux 6.6) — Bazel package //kernel-6.6 -->
  <project path="kernel/kernel-6.6"
           name="kernel-mtk"
           remote="moto"
           revision="android-15-release-vvta35" />

  <!-- Kleaf build system -->
  <project path="kernel/build/kernel"
           name="kernel-build-kernel"
           remote="moto"
           revision="android-15-release-vvta35" />

  <!-- MGK Bazel rules -->
  <project path="kernel/build/bazel_mgk_rules"
           name="kernel-build-bazel_mgk_rules"
           remote="moto"
           revision="android-15-release-vvta35" />

  <!-- Kernel build tools prebuilt -->
  <project path="prebuilts/kernel-build-tools"
           name="kernel-prebuilts-kernel-build-tools"
           remote="moto"
           revision="android-15-release-vvta35" />

  <!-- Device modules — Bazel package //kernel_device_modules-6.6 -->
  <project path="kernel/kernel_device_modules-6.6"
           name="kernel-kernel_device_modules-6.6"
           remote="moto"
           revision="android-15-release-vvta35" />

  <!-- ============================================================ -->
  <!-- Motorola / MediaTek vendor kernel modules                     -->
  <!-- ============================================================ -->
  <!--
    First vendor project carries the linkfile that creates the
    workspace symlink: kernel/vendor -> ../vendor
  -->
  <project path="vendor/mediatek/kernel_modules/connectivity/wlan/core/gen4m"
           name="vendor-mediatek-kernel_modules-connectivity-wlan-core-gen4m"
           remote="moto"
           revision="android-15-release-vvta35" />

  <project path="vendor/mediatek/kernel_modules/connectivity/bt/mt66xx"
           name="vendor-mediatek-kernel_modules-connectivity-bt-mt66xx"
           remote="moto"
           revision="android-15-release-vvta35" />

  <project path="vendor/mediatek/kernel_modules/connectivity/bt/mt76xx-sdio"
           name="vendor-mediatek-kernel_modules-connectivity-bt-mt76xx-sdio"
           remote="moto"
           revision="android-15-release-vvta35" />

  <project path="vendor/mediatek/kernel_modules/connectivity/common"
           name="vendor-mediatek-kernel_modules-connectivity-common"
           remote="moto"
           revision="android-15-release-vvta35" />

  <project path="vendor/mediatek/kernel_modules/connectivity/connfem"
           name="vendor-mediatek-kernel_modules-connectivity-connfem"
           remote="moto"
           revision="android-15-release-vvta35" />

  <project path="vendor/mediatek/kernel_modules/connectivity/conninfra"
           name="vendor-mediatek-kernel_modules-connectivity-conninfra"
           remote="moto"
           revision="android-15-release-vvta35" />

  <project path="vendor/mediatek/kernel_modules/connectivity/fmradio"
           name="vendor-mediatek-kernel_modules-connectivity-fmradio"
           remote="moto"
           revision="android-15-release-vvta35" />

  <project path="vendor/mediatek/kernel_modules/connectivity/gps"
           name="vendor-mediatek-kernel_modules-connectivity-gps"
           remote="moto"
           revision="android-15-release-vvta35" />

  <project path="vendor/mediatek/kernel_modules/connectivity/wlan/adaptor"
           name="vendor-mediatek-kernel_modules-connectivity-wlan-adaptor"
           remote="moto"
           revision="android-15-release-vvta35" />

  <!--
    vendor/mediatek/kernel_modules/gpu carries the linkfile that
    creates the workspace symlink: kernel/vendor -> ../vendor
    (src="../../.." resolves: gpu -> kernel_modules -> mediatek -> vendor)
  -->
  <project path="vendor/mediatek/kernel_modules/gpu"
           name="vendor-mediatek-kernel_modules-gpu"
           remote="moto"
           revision="android-15-release-vvta35">
    <linkfile src="../../.." dest="kernel/vendor" />
  </project>

  <project path="vendor/mediatek/kernel_modules/met_drv_v3"
           name="vendor-mediatek-kernel_modules-met_drv_v3"
           remote="moto"
           revision="android-15-release-vvta35" />

  <project path="vendor/mediatek/kernel_modules/met_drv_v2"
           name="vendor-mediatek-kernel_modules-met_drv_v2"
           remote="moto"
           revision="android-15-release-vvta35" />

  <project path="vendor/mediatek/kernel_modules/udc"
           name="vendor-mediatek-kernel_modules-udc"
           remote="moto"
           revision="android-15-release-vvta35" />

  <project path="vendor/mediatek/kernel_modules/connectivity/bt/linux_v2"
           name="vendor-mediatek-kernel_modules-connectivity-bt-linux_v2"
           remote="moto"
           revision="android-15-release-vvta35" />

  <project path="vendor/mediatek/kernel_modules/mtkcam"
           name="vendor-mediatek-kernel_modules-mtkcam"
           remote="moto"
           revision="android-15-release-vvta35" />

  <project path="vendor/mediatek/kernel_modules/afs_common_utils"
           name="vendor-mediatek-kernel_modules-afs_common_utils"
           remote="moto"
           revision="android-15-release-vvta35" />

</manifest>
